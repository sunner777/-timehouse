# 应用配置
NODE_ENV=development
PORT=3000

# MySQL配置
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=password
MYSQL_DATABASE=timehouse

# MongoDB配置
MONGODB_URI=mongodb://localhost:27017/timehouse

# Redis配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT配置
JWT_SECRET=your-secret-key
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# 日志配置
LOG_LEVEL=info

# CORS配置
CORS_ORIGIN=*

# 速率限制
RATE_LIMIT_WINDOW=900
RATE_LIMIT_MAX=100