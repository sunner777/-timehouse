# 应用配置
NODE_ENV=development
PORT=3000

# MySQL配置
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=timehouse
MYSQL_PASSWORD=your-mysql-password
MYSQL_DATABASE=timehouse
MYSQL_ROOT_PASSWORD=your-root-password

# JWT配置
JWT_SECRET=your-secret-key
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# CORS配置
CORS_ORIGIN=*

# 速率限制
RATE_LIMIT_WINDOW=900000
RATE_LIMIT_MAX=100

# 日志配置
LOG_LEVEL=info

# 火山引擎 TOS 对象存储
TOS_ACCESS_KEY_ID=your-tos-ak
TOS_ACCESS_KEY_SECRET=your-tos-sk
TOS_REGION=cn-shanghai
TOS_ENDPOINT=tos-cn-shanghai.volces.com
TOS_BUCKET=timehouse-photos-cn-shanghai

# Redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# 火山引擎 SMS 短信服务（复用TOS凭证作为默认值）
SMS_ACCESS_KEY_ID=your-tos-ak
SMS_ACCESS_KEY_SECRET=your-tos-sk
SMS_SIGN_NAME=时光家
SMS_TEMPLATE_ID=your-sms-template-id
SMS_ACCOUNT=your-sms-account